<?xml version="1.0" encoding="UTF-8"?>
<?import cn.oyzh.fx.gui.svg.label.AboutSVGLabel?>
<?import cn.oyzh.fx.gui.svg.label.KeySVGLabel?>
<?import cn.oyzh.fx.gui.svg.label.MessageSVGLabel?>
<?import cn.oyzh.fx.gui.svg.label.QuitSVGLabel?>
<?import cn.oyzh.fx.gui.svg.label.SettingSVGLabel?>
<?import cn.oyzh.fx.gui.svg.label.SnippetSVGLabel?>
<?import cn.oyzh.fx.gui.svg.label.ThemeSVGLabel?>
<?import cn.oyzh.fx.gui.svg.label.ToolsSVGLabel?>
<?import cn.oyzh.fx.gui.svg.pane.LayoutSVGPane?>
<?import cn.oyzh.fx.plus.controls.box.FXHBox?>
<?import cn.oyzh.fx.plus.controls.FXHeaderBar?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.HBox?>
<FXHeaderBar xmlns:fx="http://javafx.com/fxml/1" fx:controller="cn.oyzh.easyshell.controller.HeaderController"
             prefHeight="30">
    <content>
        <FXHBox prefHeight="30">
            <LayoutSVGPane fx:id="layoutPane" onMousePrimaryClicked="#layout" >
                <HBox.margin>
                    <Insets left="10" top="9"/>
                </HBox.margin>
            </LayoutSVGPane>
            <KeySVGLabel tipText="%base.key1Manager" onMousePrimaryClicked="#key" >
                <HBox.margin>
                    <Insets left="10" top="7"/>
                </HBox.margin>
            </KeySVGLabel>
            <SnippetSVGLabel tipText="%base.snippet" onMousePrimaryClicked="#snippet" >
                <HBox.margin>
                    <Insets left="10" top="7"/>
                </HBox.margin>
            </SnippetSVGLabel>
            <MessageSVGLabel tipText="%base.message" onMousePrimaryClicked="#message" >
                <HBox.margin>
                    <Insets left="10" top="7"/>
                </HBox.margin>
            </MessageSVGLabel>
            <ToolsSVGLabel tipText="%base.tool" onMousePrimaryClicked="#tool" >
                <HBox.margin>
                    <Insets left="10" top="7"/>
                </HBox.margin>
            </ToolsSVGLabel>
            <AboutSVGLabel tipText="%base.about" onMousePrimaryClicked="#about" >
                <HBox.margin>
                    <Insets left="10" top="7"/>
                </HBox.margin>
            </AboutSVGLabel>
            <SettingSVGLabel tipText="%base.setting" onMousePrimaryClicked="#setting" >
                <HBox.margin>
                    <Insets left="10" top="7"/>
                </HBox.margin>
            </SettingSVGLabel>
            <QuitSVGLabel tipText="%base.quit" onMousePrimaryClicked="#quit" >
                <HBox.margin>
                    <Insets left="10" top="7"/>
                </HBox.margin>
            </QuitSVGLabel>
            <ThemeSVGLabel tipText="%base.theme" onMousePrimaryClicked="#themeToggle" >
                <HBox.margin>
                    <Insets left="10" top="7"/>
                </HBox.margin>
            </ThemeSVGLabel>
        </FXHBox>
    </content>
</FXHeaderBar>
