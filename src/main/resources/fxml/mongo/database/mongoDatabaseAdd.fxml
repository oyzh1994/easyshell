<?xml version="1.0" encoding="UTF-8"?>
<?import cn.oyzh.fx.gui.button.CancelButton?>
<?import cn.oyzh.fx.gui.button.SubmitButton?>
<?import cn.oyzh.fx.gui.label.InfoLabel?>
<?import cn.oyzh.fx.gui.text.field.ClearableTextField?>
<?import cn.oyzh.fx.plus.controls.box.FXHBox?>
<?import cn.oyzh.fx.plus.controls.box.FXVBox?>
<?import cn.oyzh.fx.plus.controls.FXHeaderBar?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<FXVBox xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="cn.oyzh.easyshell.mongo.controller.database.MongoDatabaseAddController" realWidth="750"
        realHeight="300">
    <FXHeaderBar/>
    <FXVBox flexHeight="100% - 30" flexWidth="100%">
        <InfoLabel text="%base.name">
            <VBox.margin>
                <Insets left="30" top="10"/>
            </VBox.margin>
        </InfoLabel>
        <ClearableTextField require="true" fx:id="name" realHeight="30" flexWidth="100% - 180">
            <VBox.margin>
                <Insets left="30" top="5"/>
            </VBox.margin>
        </ClearableTextField>
        <FXHBox flexWidth="100%">
            <SubmitButton onAction="#add" text="%base.add">
                <HBox.margin>
                    <Insets left="30" top="15"/>
                </HBox.margin>
            </SubmitButton>
            <CancelButton>
                <HBox.margin>
                    <Insets left="15" top="15"/>
                </HBox.margin>
            </CancelButton>
        </FXHBox>
    </FXVBox>
</FXVBox>