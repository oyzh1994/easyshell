<?xml version="1.0" encoding="UTF-8"?>

<?import cn.oyzh.easyshell.fx.ShellDataEditor?>
<?import cn.oyzh.easyshell.fx.snippet.ShellSnippetListView?>
<?import cn.oyzh.fx.gui.text.field.ClearableTextField?>
<?import cn.oyzh.fx.plus.controls.box.FXHBox?>
<?import cn.oyzh.fx.plus.controls.box.FXVBox?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.VBox?>
<FXHBox xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="cn.oyzh.easyshell.popups.ShellSnippetPopupController"
        realHeight="450" realWidth="480">
    <FXVBox flexHeight="100%" flexWidth="60%">
        <ClearableTextField focusTraversable="false" fx:id="kw" flexWidth="100%" prefHeight="24" tipText="%base.search">

        </ClearableTextField>
        <ShellSnippetListView fx:id="listView" flexWidth="100%" flexHeight="100% - 30">
            <FXVBox.margin>
                <Insets top="5"/>
            </FXVBox.margin>
        </ShellSnippetListView>
    </FXVBox>
    <ShellDataEditor flexHeight="100%" flexWidth="40%" fx:id="editor" disable="true" editable="false">

    </ShellDataEditor>
</FXHBox>