<?xml version="1.0" encoding="UTF-8"?>
<?import cn.oyzh.fx.gui.svg.glyph.ClearSVGGlyph?>
<?import cn.oyzh.fx.gui.text.field.HighlightTextField?>
<?import cn.oyzh.fx.plus.controls.box.FXHBox?>
<?import cn.oyzh.fx.plus.controls.box.FXVBox?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.HBox?>
<?import cn.oyzh.fx.rich.RichMsgTextArea?>
<FXVBox xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="cn.oyzh.easyshell.mongo.tabs.message.ShellMessageTabController">
    <FXHBox realHeight="30">
        <HighlightTextField prefWidth="220" fx:id="filter" promptText="%base.searchKWTip">
            <HBox.margin>
                <Insets top="5"/>
            </HBox.margin>
        </HighlightTextField>
        <ClearSVGGlyph tipText="%base.clear"  onMousePrimaryClicked="#clearMsg">
            <HBox.margin>
                <Insets left="5" top="7"/>
            </HBox.margin>
        </ClearSVGGlyph>
    </FXHBox>
    <RichMsgTextArea fx:id="msgArea" flexHeight="100% - 30" flexWidth="100%" lineLimit="1000"/>
</FXVBox>

