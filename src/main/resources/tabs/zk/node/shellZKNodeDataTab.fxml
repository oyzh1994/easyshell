<?xml version="1.0" encoding="UTF-8"?>

<?import cn.oyzh.easyshell.fx.ShellDataEditor?>
<?import cn.oyzh.fx.editor.incubator.EditorFormatTypeComboBox?>
<?import cn.oyzh.fx.gui.combobox.CharsetComboBox?>
<?import cn.oyzh.fx.gui.svg.glyph.BinarySVGGlyph?>
<?import cn.oyzh.fx.gui.svg.glyph.ClearSVGGlyph?>
<?import cn.oyzh.fx.gui.svg.glyph.CopySVGGlyph?>
<?import cn.oyzh.fx.gui.svg.glyph.NextSVGGlyph?>
<?import cn.oyzh.fx.gui.svg.glyph.PasteSVGGlyph?>
<?import cn.oyzh.fx.gui.svg.glyph.QRCodeSVGGlyph?>
<?import cn.oyzh.fx.gui.svg.glyph.RedoSVGGlyph?>
<?import cn.oyzh.fx.gui.svg.glyph.RefreshSVGGlyph?>
<?import cn.oyzh.fx.gui.svg.glyph.SaveSVGGlyph?>
<?import cn.oyzh.fx.gui.svg.glyph.UndoSVGGlyph?>
<?import cn.oyzh.fx.gui.text.field.HighlightTextField?>
<?import cn.oyzh.fx.plus.controls.box.FXHBox?>
<?import cn.oyzh.fx.plus.controls.box.FXVBox?>
<?import cn.oyzh.fx.plus.controls.svg.SVGGlyph?>
<?import cn.oyzh.fx.plus.controls.tab.FixedTab?>
<?import cn.oyzh.fx.plus.controls.text.FXText?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.HBox?>
<FixedTab text="%base.data" fx:id="dataTab" xmlns:fx="http://javafx.com/fxml/1"
          fx:controller="cn.oyzh.easyshell.tabs.zk.node.ShellZKNodeDataTabController">
    <graphic>
        <SVGGlyph cursorType="DEFAULT" url="/font/zk/file-text.svg"/>
    </graphic>
    <FXVBox flexWidth="100%" flexHeight="100%">
        <FXHBox realHeight="30" flexWidth="100%">
            <EditorFormatTypeComboBox prefHeight="22" fx:id="format" initIndex="0" groupId="dataToBig">
                <HBox.margin>
                    <Insets left="5" top="5"/>
                </HBox.margin>
            </EditorFormatTypeComboBox>
            <SaveSVGGlyph fx:id="dataSave" disable="true"  tipText="%base.saveTip1"
                          onMousePrimaryClicked="#saveNodeData" groupId="dataToBig">
                <HBox.margin>
                    <Insets left="5" top="7"/>
                </HBox.margin>
            </SaveSVGGlyph>
            <UndoSVGGlyph disable="true" fx:id="dataUndo"  onMousePrimaryClicked="#dataUndo"
                          tipText="%base.undoTip1" groupId="dataToBig">
                <HBox.margin>
                    <Insets left="5" top="7"/>
                </HBox.margin>
            </UndoSVGGlyph>
            <RedoSVGGlyph disable="true" fx:id="dataRedo"  onMousePrimaryClicked="#dataRedo"
                          tipText="%base.redoTip1" groupId="dataToBig">
                <HBox.margin>
                    <Insets left="5" top="7"/>
                </HBox.margin>
            </RedoSVGGlyph>
            <PasteSVGGlyph onMousePrimaryClicked="#pasteData" tipText="%base.pasteTip1"
                           groupId="dataToBig">
                <HBox.margin>
                    <Insets left="5" top="7"/>
                </HBox.margin>
            </PasteSVGGlyph>
            <ClearSVGGlyph tipText="%base.clear"  onMousePrimaryClicked="#clearData" groupId="dataToBig">
                <HBox.margin>
                    <Insets left="5" top="7"/>
                </HBox.margin>
            </ClearSVGGlyph>
            <QRCodeSVGGlyph tipText="%base.qrCode"  onMousePrimaryClicked="#node2QRCode" groupId="dataToBig">
                <HBox.margin>
                    <Insets left="5" top="7"/>
                </HBox.margin>
            </QRCodeSVGGlyph>
            <RefreshSVGGlyph tipText="%base.refreshTip1"  onMousePrimaryClicked="#reloadData">
                <HBox.margin>
                    <Insets left="5" top="7"/>
                </HBox.margin>
            </RefreshSVGGlyph>
            <CopySVGGlyph tipText="%shell.zk.node.main.copy1"  onMousePrimaryClicked="#copyNode">
                <HBox.margin>
                    <Insets left="5" top="7"/>
                </HBox.margin>
            </CopySVGGlyph>
            <!-- <SVGGlyph tipText="%base.copyPath"  onMousePrimaryClicked="#copyNodePath" -->
            <!--           url="/font/zk/copy-path.svg"> -->
            <!--     <HBox.margin> -->
            <!--         <Insets left="5" top="7"/> -->
            <!--     </HBox.margin> -->
            <!-- </SVGGlyph> -->
            <BinarySVGGlyph tipText="%base.saveBinaryFile"  onMousePrimaryClicked="#saveBinaryFile">
                <HBox.margin>
                    <Insets left="5" top="7"/>
                </HBox.margin>
            </BinarySVGGlyph>
            <HighlightTextField enableFont="false" fx:id="filter" tipText="%base.searchKWTip" fontSize="11" prefHeight="22"
                                prefWidth="165">
                <HBox.margin>
                    <Insets left="5" top="5"/>
                </HBox.margin>
            </HighlightTextField>
            <NextSVGGlyph tipText="%base.find" onMousePrimaryClicked="#searchNext">
                <HBox.margin>
                    <Insets left="5" top="8"/>
                </HBox.margin>
            </NextSVGGlyph>
        </FXHBox>
        <ShellDataEditor fx:id="nodeData" flexHeight="100% - 60" flexWidth="100% - 2"
                         onKeyPressed="#onNodeDataKeyPressed" groupId="dataToBig"/>
        <FXHBox flexWidth="100%" flexHeight="30">
            <CharsetComboBox enableFontSize="false" prefHeight="22" initDefault="true" fx:id="charset" fontSize="11" prefWidth="120"
                             style="-fx-padding: 0;">
                <HBox.margin>
                    <Insets left="5" top="3"/>
                </HBox.margin>
            </CharsetComboBox>
            <FXText enableTheme="false" tipText="%base.dataSize" fx:id="dataSize"
                    style="-fx-fill: #AD0EB5B2;"
                    realHeight="22">
                <HBox.margin>
                    <Insets left="5" top="5"/>
                </HBox.margin>
            </FXText>
            <FXText enableTheme="false" tipText="%base.loadCost" fx:id="loadTime" style="-fx-fill: #009933;"
                    realHeight="22">
                <HBox.margin>
                    <Insets left="5" top="5"/>
                </HBox.margin>
            </FXText>
            <!-- <FXText fx:id="nodePath" realHeight="22"> -->
            <!--     <HBox.margin> -->
            <!--         <Insets left="5" top="5"/> -->
            <!--     </HBox.margin> -->
            <!-- </FXText> -->
            <!-- <CopySVGGlyph tipText="%base.copyPath"  onMousePrimaryClicked="#copyNodePath"> -->
            <!--     <HBox.margin> -->
            <!--         <Insets left="5" top="7"/> -->
            <!--     </HBox.margin> -->
            <!-- </CopySVGGlyph> -->
        </FXHBox>
    </FXVBox>
</FixedTab>